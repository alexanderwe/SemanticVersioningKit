bol"},"doc://dev.alexanderweiss.semantic_versionining_kit/s8CopyableP":{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/s8CopyableP","title":"Swift.Copyable","type":"unresolvable"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf#Backtracking":{"url":"\/documentation\/parsing\/oneof#Backtracking","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf#Backtracking","title":"Backtracking","abstract":[],"kind":"section","type":"topic"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Parser/Input":{"abstract":[{"type":"text","text":"The type of values this parser parses from."}],"title":"Input","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Input","kind":"identifier"}],"url":"\/documentation\/parsing\/parser\/input","required":true,"role":"symbol","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser\/Input","type":"topic","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf/parse(_:)":{"kind":"symbol","title":"parse(_:)","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"parse"},{"kind":"text","text":"("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Parsers","preciseIdentifier":"s:7Parsing5OneOfV7Parsersq0_mfp"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Input","preciseIdentifier":"s:7Parsing6ParserP5InputQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Parsers","preciseIdentifier":"s:7Parsing5OneOfV7Parsersq0_mfp"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Output","preciseIdentifier":"s:7Parsing6ParserP6OutputQa"}],"abstract":[],"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/parse(_:)","url":"\/documentation\/parsing\/oneof\/parse(_:)"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf/init(input:output:_:)":{"kind":"symbol","title":"init(input:output:_:)","role":"symbol","type":"topic","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"input"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7Parsing5OneOfV5Inputxmfp","text":"Input"},{"kind":"text","text":".Type, "},{"kind":"externalParam","text":"output"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Output","preciseIdentifier":"s:7Parsing5OneOfV6Outputq_mfp"},{"kind":"text","text":".Type, () -> "},{"kind":"typeIdentifier","text":"Parsers","preciseIdentifier":"s:7Parsing5OneOfV7Parsersq0_mfp"},{"kind":"text","text":")"}],"abstract":[],"url":"\/documentation\/parsing\/oneof\/init(input:output:_:)","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/init(input:output:_:)"}}}