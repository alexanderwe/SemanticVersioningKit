weiss.semantic_versionining_kit\/documentation\/Parsing\/Backtracking","type":"topic","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf/Parser-Implementations":{"abstract":[],"title":"Parser Implementations","url":"\/documentation\/parsing\/oneof\/parser-implementations","role":"collectionGroup","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/Parser-Implementations","kind":"article"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf/ParserPrinter-Implementations":{"abstract":[],"title":"ParserPrinter Implementations","url":"\/documentation\/parsing\/oneof\/parserprinter-implementations","role":"collectionGroup","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/ParserPrinter-Implementations","kind":"article"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Parser":{"kind":"symbol","title":"Parser","role":"symbol","navigatorTitle":[{"text":"Parser","kind":"identifier"}],"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Parser","kind":"identifier"}],"abstract":[{"text":"Declares a type that can incrementally parse an ","type":"text"},{"code":"Output","type":"codeVoice"},{"text":" value from an ","type":"text"},{"code":"Input","type":"codeVoice"},{"text":" value.","type":"text"}],"url":"\/documentation\/parsing\/parser","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Parser/Output":{"abstract":[{"text":"The type of values parsed by this parser.","type":"text"}],"title":"Output","fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Output","kind":"identifier"}],"url":"\/documentation\/parsing\/parser\/output","required":true,"role":"symbol","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser\/Output","type":"topic","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing":{"kind":"symbol","title":"Parsing","role":"collection","type":"topic","abstract":[],"url":"\/documentation\/parsing","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf/parsers":{"abstract":[],"title":"parsers","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"parsers"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:7Parsing5OneOfV7Parsersq0_mfp","text":"Parsers"}],"url":"\/documentation\/parsing\/oneof\/parsers","role":"symbol","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/parsers","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/OneOf":{"abstract":[{"text":"A parser that attempts to run a number of parsers till one succeeds.","type":"text"}],"title":"OneOf","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OneOf","kind":"identifier"}],"navigatorTitle":[{"text":"OneOf","kind":"identifier"}],"url":"\/documentation\/parsing\/oneof","role":"symbol","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Always":{"abstract":[{"type":"text","text":"A parser that always succeeds with the given value, and does not consume any input."}],"title":"Always","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Always"}],"navigatorTitle":[{"kind":"identifier","text":"Always"}],"url":"\/documentation\/parsing\/always","role