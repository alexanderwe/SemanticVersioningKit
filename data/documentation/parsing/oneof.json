{"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/init(input:output:_:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/parsers"],"anchor":"Instance-Properties","generated":true},{"title":"Instance Methods","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/parse(_:)"],"anchor":"Instance-Methods","generated":true},{"title":"Default Implementations","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/Parser-Implementations","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/ParserPrinter-Implementations"],"anchor":"Default-Implementations","generated":true}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing"]]},"abstract":[{"text":"A parser that attempts to run a number of parsers till one succeeds.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/parsing\/oneof"]}],"identifier":{"url":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/ParserPrinter","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/s8CopyableP","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/s9EscapableP"],"kind":"relationships","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["iOS","iPadOS","Mac Catalyst","macOS","tvOS","visionOS","watchOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OneOf"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Input"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Output"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Parsers"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Input"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"Parsers"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser\/Input","text":"Input","preciseIdentifier":"s:7Parsing6ParserP5InputQa"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Output"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"Parsers"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser\/Output","text":"Output","preciseIdentifier":"s:7Parsing6ParserP6OutputQa"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Parsers"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser","text":"Parser","preciseIdentifier":"s:7Parsing6ParserP"}]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Use this parser to list out a number of parsers in a "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOfBuilder","isActive":true},{"type":"text","text":" result builder block."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example uses "},{"isActive":true,"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf"},{"type":"text","text":" to parse an enum value. To do so, it spells out a list of"},{"type":"text","text":" "},{"type":"text","text":"parsers to "},{"code":"OneOf","type":"codeVoice"},{"type":"text","text":", one for each case:"}],"type":"paragraph"},{"code":["enum Currency { case eur, gbp, usd }","","let currency = OneOf {","  \"€\".map { Currency.eur }","  \"£\".map { Currency.gbp }","  \"$\".map { Currency.usd }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"This parser fails if every parser inside fails:"}],"type":"paragraph"},{"syntax":"swift","code":["var input = \"London, Hello!\"[...]","try OneOf { \"New York\"; \"Berlin\" }.parse(&input)","","\/\/ error: multiple failures occurred","\/\/","\/\/ error: unexpected input","\/\/  --> input:1:1","\/\/ 1 | London, Hello!","\/\/   | ^ expected \"New York\"","\/\/   | ^ expected \"Berlin\""],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"If you are parsing input that should coalesce into some default, avoid using a final ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Always","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"parser, and instead opt for a trailing ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf\/replaceError(with:)","type":"reference","isActive":true},{"text":", which returns a parser that","type":"text"},{"text":" ","type":"text"},{"text":"cannot fail:","type":"text"}]},{"syntax":"swift","code":["enum Currency { case eur, gbp, usd, unknown }","","let currency = OneOf {","  \"€\".map { Currency.eur }","  \"£\".map { Currency.gbp }","  \"$\".map { Currency.usd }","}",".replaceError(with: Currency.unknown)","","currency.parse(\"$\")  \/\/ Currency.usd","currency.parse(\"฿\")  \/\/ Currency.unknown"],"type":"codeListing"},{"text":"Specificity","level":2,"anchor":"Specificity","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The order of the parsers in the above ","type":"text"},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf","type":"reference"},{"text":" does not matter because each of “€”, “£” and “$”","type":"text"},{"text":" ","type":"text"},{"text":"are mutually exclusive, i.e. at most one will succeed on any given input.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"However, that is not always true, and when the parsers are not mutually exclusive (i.e. multiple","type":"text"},{"text":" ","type":"text"},{"text":"can succeed on a given input) you must order them from most specific to least specific. That is,","type":"text"},{"text":" ","type":"text"},{"text":"the first parser should succeed on the fewest number of inputs and the last parser should","type":"text"},{"text":" ","type":"text"},{"text":"succeed on the most number of inputs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, suppose you wanted to parse a simple CSV format into a doubly-nested array of","type":"text"},{"text":" ","type":"text"},{"text":"strings, and the fields in the CSV are allowed to contain commas themselves as long as they","type":"text"},{"text":" ","type":"text"},{"text":"are quoted:","type":"text"}]},{"syntax":"swift","code":["let input = #\"\"\"","lastName,firstName","McBlob,Blob","\"McBlob, Esq.\",Blob Jr.","\"McBlob, MD\",Blob Sr.","\"\"\"#"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Here we have a list of last and first names separated by a comma, and some of the last names are","type":"text"},{"text":" ","type":"text"},{"text":"quoted because they contain commas.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In order to safely parse this we must first try parsing a field as a quoted field, and then only","type":"text"},{"text":" ","type":"text"},{"text":"if that fails we can parse a plain field that takes everything up until the next comma or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"newline:"}]},{"type":"codeListing","syntax":"swift","code":["let quotedField = Parse {","  \"\\\"\"","  Prefix { $0 != \"\\\"\" }","  \"\\\"\"","}","let plainField = Prefix { $0 != \",\" && $0 != \"\\n\" }","","let field = OneOf {","  quotedField","  plainField","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then we can parse many fields to form an array of fields making up a line, and then parse many"},{"text":" ","type":"text"},{"type":"text","text":"lines to make up a full, doubly-nested array for the CSV:"}]},{"syntax":"swift","code":["let line = Many { field } separator: { \",\" }","let csv = Many { line } separator: { \"\\n\" }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Running this parser on the input shows that it properly isolates each field of the CSV, even"},{"type":"text","text":" "},{"type":"text","text":"fields that are quoted and contain a comma:"}],"type":"paragraph"},{"code":["XCTAssertEqual(","  try csv.parse(input),","  [","    [\"lastName\", \"firstName\"],","    [\"McBlob\", \"Blob\"],","    [\"McBlob, Esq.\", \"Blob Jr.\"],","    [\"McBlob, MD\", \"Blob Sr.\"],","  ]",")","\/\/ ✅"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The reason this parser works is because the "},{"code":"quotedField","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"plainField","type":"codeVoice"},{"text":" parsers are listed in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a very specific order inside the "},{"code":"OneOf","type":"codeVoice"},{"type":"text","text":":"}]},{"code":["let field = OneOf {","  quotedField","  plainField","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"quotedField"},{"type":"text","text":" parser is a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"more"}]},{"type":"text","text":" specific parser in that it will succeed on fewer inputs"},{"type":"text","text":" "},{"type":"text","text":"than the "},{"type":"codeVoice","code":"plainField"},{"type":"text","text":" parser does. For example:"}],"type":"paragraph"},{"code":["try quotedField.parse(\"Blob Jr.\") \/\/ ❌","try plainField.parse(\"Blob Jr.\")  \/\/ ✅"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Whereas the "},{"type":"codeVoice","code":"plainField"},{"type":"text","text":" parser will happily succeed on anything the "},{"type":"codeVoice","code":"quotedField"},{"type":"text","text":" parser will"},{"type":"text","text":" "},{"type":"text","text":"succeed on:"}],"type":"paragraph"},{"code":["try quotedField.parse(\"\\\"Blob, Esq\\\"\") \/\/ ✅","try plainField.parse(\"\\\"Blob, Esq\\\"\")  \/\/ ✅"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"For this reason the "},{"type":"codeVoice","code":"quotedField"},{"type":"text","text":" parser must be listed first so that it can try its logic"},{"type":"text","text":" "},{"type":"text","text":"first, which succeeds less frequently, before then trying the "},{"type":"codeVoice","code":"plainField"},{"type":"text","text":" parser, which"},{"type":"text","text":" "},{"type":"text","text":"succeeds more often."}],"type":"paragraph"},{"text":"Backtracking","level":2,"anchor":"Backtracking","type":"heading"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf","isActive":true},{"type":"text","text":" parser is the primary tool for introducing backtracking into your parsers,"},{"type":"text","text":" "},{"type":"text","text":"which means to undo the consumption of a parser when it fails. For more information, see the"},{"type":"text","text":" "},{"type":"text","text":"article "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf#Backtracking","isActive":true},{"type":"text","text":" and the "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Backtracking","isActive":true},{"type":"text","text":" parser."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"While "},{"isActive":true,"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf"},{"type":"text","text":" does undo any input consumption before running each parser listed"},{"type":"text","text":" "},{"type":"text","text":"in the builder closure, it does "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" undo the consumption of the last parser. If you want to"},{"type":"text","text":" "},{"type":"text","text":"enforce backtracking for the entire "},{"isActive":true,"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/OneOf"},{"type":"text","text":" parser you need to further wrap it inside the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Backtracking"},{"type":"text","text":" parser."}]}]}]}],"metadata":{"title":"OneOf","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"OneOf"}],"navigatorTitle":[{"text":"OneOf","kind":"identifier"}],"role":"symbol","symbolKind":"struct","modules":[{"name":"Parsing"}],"roleHeading":"Structure","externalID":"s:7Parsing5OneOfV"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://dev.alexanderweiss.semantic_versionining_kit/s9EscapableP":{"title":"Swift.Escapable","type":"unresolvable","identifier":"doc:\/\/dev.alexanderwei