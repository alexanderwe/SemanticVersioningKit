acters can be digits. ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"E.g.","type":"text"}]},{"type":"text","text":", "},{"type":"codeVoice","code":"foo123"},{"type":"text","text":" "},{"type":"text","text":"is a valid identifier, but "},{"type":"codeVoice","code":"123foo"},{"type":"text","text":" is not. We can create an identifier parser by using "},{"type":"codeVoice","code":"Peek"},{"type":"text","text":" "},{"type":"text","text":"to first check if the input starts with a letter or underscore, and if it does, return the"},{"type":"text","text":" "},{"type":"text","text":"remainder of the input up to the first character that is not a letter, a digit, or an"},{"type":"text","text":" "},{"type":"text","text":"underscore."}],"type":"paragraph"},{"syntax":"swift","code":["let identifier = Parse {","  Peek { Prefix(1) { $0.isLetter || $0 == \"_\" } }","  Prefix { $0.isNumber || $0.isLetter || $0 == \"_\" }","}","","try identifier.parse(\"foo123\") \/\/ ✅ \"foo123\"","try identifier.parse(\"_foo123\") \/\/ ✅ \"_foo123\"","try identifier.parse(\"1_foo123\") \/\/ ❌","\/\/ error: unexpected input","\/\/  --> input:1:1","\/\/ 1 | 1_foo123","\/\/   | ^ expected 1 element satisfying predicate"],"type":"codeListing"}]}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing"]]},"topicSections":[{"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Peek\/init(_:)"],"generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Peek\/upstream"],"anchor":"Instance-Properties","generated":true},{"title":"Instance Methods","identifiers":["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Peek\/parse(_:)","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Peek\/print(_:into:)"],"anchor":"Instance-Method