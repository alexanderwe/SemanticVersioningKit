{"abstract":[{"type":"text","text":"A conversion from a tuple of values into a struct and a struct into a tuple of values, using a"},{"type":"text","text":" "},{"type":"text","text":"memberwise initializer."}],"primaryContentSections":[{"declarations":[{"platforms":["iOS","iPadOS","Mac Catalyst","macOS","tvOS","visionOS","watchOS"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"memberwise"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Values"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Struct"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"initializer"},{"kind":"text","text":": "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6ValuesL_qd__mfp","text":"Values"},{"kind":"text","text":") -> "},{"text":"Struct","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6StructL_qd_0_mfp"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"text":" == ","kind":"text"},{"text":"Conversions","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing11ConversionsO"},{"text":".","kind":"text"},{"text":"Memberwise","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Memberwise","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing11ConversionsO10MemberwiseV"},{"text":"<","kind":"text"},{"text":"Values","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Struct","kind":"typeIdentifier"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"initializer","content":[{"type":"paragraph","inlineContent":[{"text":"A memberwise initializer where ","type":"text"},{"code":"Values","type":"codeVoice"},{"type":"text","text":" directly maps to the memory"},{"type":"text","text":" "},{"type":"text","text":"layout of "},{"code":"Root","type":"codeVoice"},{"type":"text","text":", for example the internal, default initializer that is automatically"},{"type":"text","text":" "},{"type":"text","text":"synthesized for structs."}]}]}]},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"A conversion that can embed a tuple of values into a struct, and destructure a"},{"type":"text","text":" "},{"type":"text","text":"struct back into a tuple of values."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Useful for transforming the output of a "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/ParserPrinter","isActive":true},{"type":"text","text":" into a struct."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, given a simple "},{"code":"Coordinate","type":"codeVoice"},{"type":"text","text":" struct, we can build a parser-printer using"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["struct Coordinate {","  var x: Double","  var y: Double","}","","let coord = ParsePrint(.memberwise(Coordinate.init(x:y:))) {","  \"(\"","  Double.parser()","  \",\"","  Double.parser()","  \")\"","}","","try coord.parse(\"(1,-2)\")           \/\/ Coordinate(x: 1.0, y: -2.0)","coord.print(.init(x: -5, y: 10))  \/\/ \"(-5.0,10.0)\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To transform the output of a "},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/ParserPrinter","type":"reference","isActive":true},{"type":"text","text":" into an enum, see "},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversion\/case(_:)-4j2n7","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Careful usage","anchor":"Careful-usage"},{"inlineContent":[{"type":"text","text":"This conversion works by using the memberwise initializer you supply to "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)","isActive":true},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"order to turn tuples into a struct, and it uses "},{"type":"codeVoice","code":"unsafeBitcast"},{"text":" to turn the struct back into","type":"text"},{"text":" ","type":"text"},{"text":"a tuple. Because of this, it is ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" valid to use ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)","type":"reference","isActive":true},{"type":"text","text":" with anything other than"},{"text":" ","type":"text"},{"text":"the default synthesized memberwise initializer that structs are given for free by the compiler","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as that function most correctly maps the data inside a struct to its tuple representation,"},{"text":" ","type":"text"},{"type":"text","text":"even enforcing the order of the fields."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you alter the initializer in any way you run the risk of introducing subtle bugs into"},{"type":"text","text":" "},{"type":"text","text":"your parser-printer and potentially causing crashes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, suppose we provided an alternative initializer to "},{"type":"codeVoice","code":"Coordinate"},{"type":"text","text":" above that"},{"type":"text","text":" "},{"type":"text","text":"allowed you to create a coordinate from a radius and angle measured in degrees:"}],"type":"paragraph"},{"code":["extension Coordinate {","  init(radius: Double, angle: Double) {","    self.x = radius * cos(angle * Double.pi \/ 180)","    self.y = radius * sin(angle * Double.pi \/ 180)","  }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This may seem innocent enough, but it is ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" safe to use this initializer with","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)","type":"reference","isActive":true},{"text":". The following parser-printer will correctly parse a radius and angle into","type":"text"},{"type":"text","text":" "},{"text":"an x\/y coordinate:","type":"text"}],"type":"paragraph"},{"code":["let coord = ParserPrint(.memberwise(Coordinate.init(radius:angle:))) {","  Double.parser()","  \" @ \"","  Double.parser()","  \"°\"","}","","try coord.parse(\"1 @ 90°\")  \/\/ (x: 0, y: 1)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"However, printing a coordinate will "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" convert it back into a radius and angle, and"},{"type":"text","text":" "},{"type":"text","text":"instead will erroneously use (0, 1) as the radius and angle:"}],"type":"paragraph"},{"code":["try coord.print(.init(x: 0, y: 1))  \/\/ \"0 @ 1°\""],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This means this parser-printer does not round trip (see "},{"text":"doc:Roundtripping","type":"text"},{"text":"), ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"i.e.","type":"text"}]},{"type":"text","text":" if we"},{"type":"text","text":" "},{"type":"text","text":"parse and input and then print that output we do not get back the original input we started"},{"type":"text","text":" "},{"type":"text","text":"with:"}],"type":"paragraph"},{"code":["try coord.print(try coord.parse(\"1 @ 90°\")) == \"1 @ 90°\"  \/\/ ❌"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Further, it is possible to provide a custom initializer for a type that either re-orders the","type":"text"},{"text":" ","type":"text"},{"text":"fields or add\/removes fields, both of which will cause the underlying ","type":"text"},{"code":"unsafeBitCast","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"crash. For example, we could have a "},{"code":"User","type":"codeVoice"},{"type":"text","text":" struct that holds onto a string for the bio and an"},{"type":"text","text":" "},{"type":"text","text":"integer for the id, and provide a custom initializer so that the id is provided first:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct User {","  let bio: String","  let id: Int","  init(id: Int, bio: String) {","    self.bio = bio","    self.id = id","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"However, using this initializer with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)","type":"reference"},{"text":" will cause printing to crash because","type":"text"},{"text":" ","type":"text"},{"text":"it will try to bitcast a ","type":"text"},{"code":"(String, Int)","type":"codeVoice"},{"text":" struct into a ","type":"text"},{"code":"(Int, String)","type":"codeVoice"},{"text":" tuple:","type":"text"}]},{"syntax":"swift","code":["let user = ParsePrint(.memberwise(User.init(id:bio:))) {","  Int.parser()","  \",\"","  Rest()","}","","try user.print(.init(id: 42, bio: \"Hello world!\"))  \/\/ ❌"],"type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/parsing\/conversions\/map\/memberwise(_:)"]}],"metadata":{"title":"memberwise(_:)","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"memberwise"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Values"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Struct"},{"kind":"text","text":">(("},{"kind":"typeIdentifier","text":"Values","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6ValuesL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Struct","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6StructL_qd_0_mfp"},{"kind":"text","text":") -> "},{"text":"Self","kind":"typeIdentifier"}],"modules":[{"name":"Parsing"}],"extendedModule":"Parsing","role":"symbol","roleHeading":"Type Method","externalID":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ::SYNTHESIZED::s:7Parsing11ConversionsO3MapV","symbolKind":"method"},"kind":"symbol","references":{"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversions/Map":{"kind":"symbol","title":"Conversions.Map","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Map"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Map"}],"abstract":[{"type":"text","text":"A conversion that composes two conversions together by composing their"},{"type":"text","text":" "},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversion\/apply(_:)","type":"reference","isActive":true},{"type":"text","text":" functions and "},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversion\/unapply(_:)","type":"reference","isActive":true},{"type":"text","text":" functions together."}],"url":"\/documentation\/parsing\/conversions\/map","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversions":{"kind":"symbol","title":"Conversions","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Conversions"}],"type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Conversions"}],"abstract":[{"type":"text","text":"A namespace for types that serve as conversions."}],"url":"\/documentation\/parsing\/conversions","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversions/Memberwise":{"abstract":[],"title":"Conversions.Memberwise","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Memberwise"}],"navigatorTitle":[{"kind":"identifier","text":"Memberwise"}],"url":"\/documentation\/parsing\/conversions\/memberwise","role":"symbol","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Memberwise","type":"topic","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing":{"kind":"symbol","title":"Parsing","role":"collection","type":"topic","abstract":[],"url":"\/documentation\/parsing","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversions/Map/memberwise(_:)":{"kind":"symbol","title":"memberwise(_:)","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"memberwise"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Values"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Struct"},{"kind":"text","text":">(("},{"kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6ValuesL_qd__mfp","text":"Values"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6StructL_qd_0_mfp","text":"Struct"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"}],"abstract":[{"type":"text","text":"A conversion from a tuple of values into a struct and a struct into a tuple of values, using a"},{"type":"text","text":" "},{"type":"text","text":"memberwise initializer."}],"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Map\/memberwise(_:)","url":"\/documentation\/parsing\/conversions\/map\/memberwise(_:)"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/ParserPrinter":{"abstract":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Parser"},{"type":"text","text":" that can incrementally “print” an output value back into an input."}],"title":"ParserPrinter","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ParserPrinter"}],"navigatorTitle":[{"kind":"identifier","text":"ParserPrinter"}],"url":"\/documentation\/parsing\/parserprinter","role":"symbol","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/ParserPrinter","type":"topic","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversion/unapply(_:)":{"abstract":[{"type":"text","text":"Attempts to transform an output back into an input."}],"title":"unapply(_:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"unapply","kind":"identifier"},{"kind":"text","text":"("},{"text":"Output","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionP6OutputQa"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Input","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionP5InputQa"}],"url":"\/documentation\/parsing\/conversion\/unapply(_:)","required":true,"role":"symbol","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversion\/unapply(_:)","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversion/apply(_:)":{"kind":"symbol","title":"apply(_:)","role":"symbol","type":"topic","required":true,"fragments":[{"kind":"keyword",