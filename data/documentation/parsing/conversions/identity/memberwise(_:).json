{"hierarchy":{"paths":[["doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions","doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity"]]},"abstract":[{"text":"A conversion from a tuple of values into a struct and a struct into a tuple of values, using a","type":"text"},{"text":" ","type":"text"},{"text":"memberwise initializer.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/parsing\/conversions\/identity\/memberwise(_:)"]}],"identifier":{"url":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity\/memberwise(_:)","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"memberwise","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Values","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Struct","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"initializer","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"attribute"},{"text":" (","kind":"text"},{"text":"Values","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6ValuesL_qd__mfp"},{"text":") -> ","kind":"text"},{"text":"Struct","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6StructL_qd_0_mfp"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":" == ","kind":"text"},{"text":"Conversions","kind":"typeIdentifier","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions","preciseIdentifier":"s:7Parsing11ConversionsO"},{"text":".","kind":"text"},{"text":"Memberwise","kind":"typeIdentifier","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Memberwise","preciseIdentifier":"s:7Parsing11ConversionsO10MemberwiseV"},{"text":"<","kind":"text"},{"text":"Values","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Struct","kind":"typeIdentifier"},{"text":">","kind":"text"}],"platforms":["iOS","iPadOS","Mac Catalyst","macOS","tvOS","visionOS","watchOS"]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A memberwise initializer where "},{"code":"Values","type":"codeVoice"},{"type":"text","text":" directly maps to the memory"},{"type":"text","text":" "},{"type":"text","text":"layout of "},{"code":"Root","type":"codeVoice"},{"type":"text","text":", for example the internal, default initializer that is automatically"},{"type":"text","text":" "},{"type":"text","text":"synthesized for structs."}],"type":"paragraph"}],"name":"initializer"}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"text":"A conversion that can embed a tuple of values into a struct, and destructure a","type":"text"},{"text":" ","type":"text"},{"text":"struct back into a tuple of values.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Useful for transforming the output of a ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/ParserPrinter","type":"reference","isActive":true},{"text":" into a struct.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, given a simple ","type":"text"},{"code":"Coordinate","type":"codeVoice"},{"text":" struct, we can build a parser-printer using","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity\/memberwise(_:)","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"code":["struct Coordinate {","  var x: Double","  var y: Double","}","","let coord = ParsePrint(.memberwise(Coordinate.init(x:y:))) {","  \"(\"","  Double.parser()","  \",\"","  Double.parser()","  \")\"","}","","try coord.parse(\"(1,-2)\")           \/\/ Coordinate(x: 1.0, y: -2.0)","coord.print(.init(x: -5, y: 10))  \/\/ \"(-5.0,10.0)\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"To transform the output of a "},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/ParserPrinter","type":"reference"},{"type":"text","text":" into an enum, see "},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversion\/case(_:)-4j2n7","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Careful usage","anchor":"Careful-usage","type":"heading"},{"inlineContent":[{"type":"text","text":"This conversion works by using the memberwise initializer you supply to "},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity\/memberwise(_:)","type":"reference"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"order to turn tuples into a struct, and it uses "},{"code":"unsafeBitcast","type":"codeVoice"},{"type":"text","text":" to turn the struct back into"},{"type":"text","text":" "},{"type":"text","text":"a tuple. Because of this, it is "},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"type":"text","text":" valid to use "},{"isActive":true,"identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity\/memberwise(_:)","type":"reference"},{"type":"text","text":" with anything other than"},{"type":"text","text":" "},{"type":"text","text":"the default synthesized memberwise initializer that structs are given for free by the compiler"},{"type":"text","text":" "},{"type":"text","text":"as that function most correctly maps the data inside a struct to its tuple representation,"},{"type":"text","text":" "},{"type":"text","text":"even enforcing the order of the fields."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you alter the initializer in any way you run the risk of introducing subtle bugs into"},{"type":"text","text":" "},{"type":"text","text":"your parser-printer and potentially causing crashes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, suppose we provided an alternative initializer to "},{"code":"Coordinate","type":"codeVoice"},{"type":"text","text":" above that"},{"type":"text","text":" "},{"type":"text","text":"allowed you to create a coordinate from a radius and angle measured in degrees:"}],"type":"paragraph"},{"code":["extension Coordinate {","  init(radius: Double, angle: Double) {","    self.x = radius * cos(angle * Double.pi \/ 180)","    self.y = radius * sin(angle * Double.pi \/ 180)","  }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"This may seem innocent enough, but it is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" safe to use this initializer with"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity\/memberwise(_:)","isActive":true},{"type":"text","text":". The following parser-printer will correctly parse a radius and angle into"},{"type":"text","text":" "},{"type":"text","text":"an x\/y coordinate:"}],"type":"paragraph"},{"code":["let coord = ParserPrint(.memberwise(Coordinate.init(radius:angle:))) {","  Double.parser()","  \" @ \"","  Double.parser()","  \"°\"","}","","try coord.parse(\"1 @ 90°\")  \/\/ (x: 0, y: 1)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"However, printing a coordinate will ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" convert it back into a radius and angle, and","type":"text"},{"type":"text","text":" "},{"text":"instead will erroneously use (0, 1) as the radius and angle:","type":"text"}]},{"code":["try coord.print(.init(x: 0, y: 1))  \/\/ \"0 @ 1°\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This means this parser-printer does not round trip (see ","type":"text"},{"type":"text","text":"doc:Roundtripping"},{"text":"), ","type":"text"},{"inlineContent":[{"type":"text","text":"i.e."}],"type":"emphasis"},{"type":"text","text":" if we"},{"type":"text","text":" "},{"text":"parse and input and then print that output we do not get back the original input we started","type":"text"},{"type":"text","text":" "},{"text":"with:","type":"text"}]},{"code":["try coord.print(try coord.parse(\"1 @ 90°\")) == \"1 @ 90°\"  \/\/ ❌"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Further, it is possible to provide a custom initializer for a type that either re-orders the"},{"type":"text","text":" "},{"type":"text","text":"fields or add\/removes fields, both of which will cause the underlying "},{"type":"codeVoice","code":"unsafeBitCast"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"crash. For example, we could have a "},{"code":"User","type":"codeVoice"},{"type":"text","text":" struct that holds onto a string for the bio and an"},{"type":"text","text":" "},{"type":"text","text":"integer for the id, and provide a custom initializer so that the id is provided first:"}],"type":"paragraph"},{"code":["struct User {","  let bio: String","  let id: Int","  init(id: Int, bio: String) {","    self.bio = bio","    self.id = id","  }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"However, using this initializer with ","type":"text"},{"type":"reference","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Identity\/memberwise(_:)","isActive":true},{"type":"text","text":" will cause printing to crash because"},{"text":" ","type":"text"},{"type":"text","text":"it will try to bitcast a "},{"code":"(String, Int)","type":"codeVoice"},{"type":"text","text":" struct into a "},{"code":"(Int, String)","type":"codeVoice"},{"type":"text","text":" tuple:"}]},{"type":"codeListing","syntax":"swift","code":["let user = ParsePrint(.memberwise(User.init(id:bio:))) {","  Int.parser()","  \",\"","  Rest()","}","","try user.print(.init(id: 42, bio: \"Hello world!\"))  \/\/ ❌"]}],"kind":"content"}],"metadata":{"title":"memberwise(_:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"memberwise","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Values","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Struct","kind":"genericParameter"},{"text":">((","kind":"text"},{"text":"Values","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6ValuesL_qd__mfp"},{"text":") -> ","kind":"text"},{"text":"Struct","kind":"typeIdentifier","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ6StructL_qd_0_mfp"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"}],"role":"symbol","symbolKind":"method","modules":[{"name":"Parsing"}],"extendedModule":"Parsing","roleHeading":"Type Method","externalID":"s:7Parsing10ConversionPAAE10memberwiseyAA11ConversionsO10MemberwiseVy_qd__qd_0_Gqd_0_qd__cAIRszr0_lFZ::SYNTHESIZED::s:7Parsing11ConversionsO8IdentityV"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing":{"kind":"symbol","title":"Parsing","role":"collection","type":"topic","abstract":[],"url":"\/documentation\/parsing","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversions/Memberwise":{"abstract":[],"title":"Conversions.Memberwise","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Memberwise"}],"navigatorTitle":[{"kind":"identifier","text":"Memberwise"}],"url":"\/documentation\/parsing\/conversions\/memberwise","role":"symbol","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/Memberwise","type":"topic","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Conversions/Identity/memberwise(_:)":{"abstract":[{"type":"text","text":"A conversion from a tuple of values into a struct and a struct into a tuple of values, using a"},{"type":"text","text":" "},{"type":"text","text":"memberwise initializer."}],"title":"memberwise(_:)","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"memberwise","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Values","kind":"genericParameter"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"Struct"},{"text":">((","kind":"text"},{"kind":"typeIdentifier","text":"Values","preciseIdentifier":"s:7Parsing10ConversionPAAE10memberwiseyAA11Conversions