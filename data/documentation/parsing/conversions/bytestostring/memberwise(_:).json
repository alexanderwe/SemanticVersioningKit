ence","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/PrependableCollection"},{"type":"text","text":" of UTF-8 bytes to a string."}],"title":"Conversions.BytesToString","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BytesToString","kind":"identifier"}],"navigatorTitle":[{"text":"BytesToString","kind":"identifier"}],"url":"\/documentation\/parsing\/conversions\/bytestostring","role":"symbol","type":"topic","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/Conversions\/BytesToString","kind":"symbol"},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/PrependableCollection":{"role":"symbol","url":"\/documentation\/parsing\/prependablecollection","identifier":"doc:\/\/dev.alexanderweiss.semantic_versionining_kit\/documentation\/Parsing\/PrependableCollection","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PrependableCollection"}],"type":"topic","kind":"symbol","abstract":[{"type":"text","text":"A collection that supports empty initialization and the ability to prepend a sequence of"},{"text":" ","type":"text"},{"type":"text","text":"elements of elements to itself."}],"title":"PrependableCollection","navigatorTitle":[{"kind":"identifier","text":"PrependableCollection"}]},"doc://dev.alexanderweiss.semantic_versionining_kit/documentation/Parsing/Parser":{"kind":"symbol","title":"Parser","role":"symbol","navigatorTitle":[{"text":"Parser","kind":"identifier"}],"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Parser","kind":"identifier"}],"abstract":[{"text":"Declares a type that can incrementally parse an ","type":"text"},{"code":"Output","type":"codeVoice"},{"text":" value from an ","type":"text"},{"code":"Input","type":"codeVoice"},{"text":" value.","type":"text"}],"url":"\/documentation\/parsing\/parser","identifier":"d